# Agent OS Backend — copy to .env and set values

# Server
PORT=3001

# OpenClaw workspace (required for MD file management)
# Path to the directory containing SOUL.md, AGENTS.md, MEMORY.md
OPENCLAW_WORKSPACE_PATH=

# OpenClaw gateway (required for chat with agents)
# Base URL of the gateway (default port 18789)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# Token or password (see gateway.auth in OpenClaw config)
OPENCLAW_GATEWAY_TOKEN=

# Optional: persistent data directory (default: backend/data)
# AGENT_OS_DATA_DIR=./data

# OpenAI (required for Run COO and "Run standup now": standup + CEO summary)
OPENAI_API_KEY=
# Optional: OPENAI_COO_MODEL=gpt-4o-mini
