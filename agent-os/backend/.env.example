# Agent OS Backend — copy to .env and set values

# Server
PORT=3001

# OpenClaw workspace (required for MD file management)
OPENCLAW_WORKSPACE_PATH=

# OpenClaw gateway (required for chat with agents)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# Job Discovery browser runs need longer than default chat (scroll + paginate + detail pages)
# OPENCLAW_DISCOVERY_TIMEOUT_MS=900000
# OPENCLAW_FETCH_TIMEOUT_MS=240000

# Platform admin (seeded on first startup if no admin exists)
# AGENT_OS_ADMIN_EMAIL=admin@agent-os.local
# AGENT_OS_ADMIN_PASSWORD=admin-change-me
# AGENT_OS_SESSION_DAYS=14

# Bala CEO — owns existing platform DB (job profiles under ceo_user_id=default)
# AGENT_OS_BALA_CEO_ID=ceo-bala
# AGENT_OS_BALA_EMAIL=bala@agent-os.local
# AGENT_OS_BALA_PASSWORD=bala-change-me
# AGENT_OS_BALA_NAME=Balaji Muthukrishnan
# AGENT_OS_BALA_REGION=Singapore

# Legacy dev CEO id when not using auth headers (prefer JWT after login)
# AGENT_OS_CEO_USER_ID=default

# ---- LLM / OpenAPI-compliant (COO, intent, summarize-url) ----
# Primary and secondary = different providers using same OpenAI SDK (e.g. OpenAI, Ollama, DeepSeek). Secondary is tried if primary fails.

# Primary endpoint
OPENAI_PRIMARY_BASE_URL=https://api.openai.com/v1
OPENAI_PRIMARY_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-4o-mini
# Legacy: OPENAI_API_KEY and OPENAI_BASE_URL work as primary if OPENAI_PRIMARY_* not set

# Secondary endpoint (optional)
# OPENAI_SECONDARY_BASE_URL=https://api.deepseek.com/v1
# OPENAI_SECONDARY_API_KEY=
# OPENAI_SECONDARY_MODEL=deepseek-chat

# Overrides per use case
# OPENAI_COO_MODEL=
# OPENAI_INTENT_MODEL=
# TOOLS_SUMMARIZE_MODEL=

# ---- Content tools: summarize-url ----
# Uses LLM primary/secondary above (same endpoint + key + model). Optional override:
# TOOLS_SUMMARIZE_MODEL=
# TOOLS_SUMMARIZE_TIMEOUT_MS=10000
# TOOLS_SUMMARIZE_MAX_BYTES=512000
# TOOLS_SUMMARIZE_ALLOWED_DOMAINS=

# ---- Content tools: image (OpenAI-compatible / GPT-image) ----
# Primary uses OPENAI_PRIMARY_* above; optional image-specific model. Secondary = separate endpoint/key/model.
# DALL·E 2/3 are retired for many accounts — use gpt-image-1 or gpt-image-1-mini (returns base64; backend saves to /api/media/openclaw/generated/).

# Primary (reuses OPENAI_PRIMARY_BASE_URL and OPENAI_PRIMARY_API_KEY if not set below)
# TOOLS_IMAGE_MODEL=gpt-image-1
# TOOLS_IMAGE_SIZE=1024x1024
# TOOLS_IMAGE_QUALITY=medium
# TOOLS_IMAGE_STYLE=natural
# TOOLS_IMAGE_MAX_PROMPT_CHARS=1000

# Secondary image provider (optional)
# OPENAI_SECONDARY_BASE_URL= (same as LLM secondary if same provider)
# OPENAI_SECONDARY_API_KEY=
# TOOLS_IMAGE_SECONDARY_MODEL=dall-e-3

# ---- Content tools: video (Replicate) ----
# Primary and secondary = different Replicate endpoint/token/model.

# Primary (same REPLICATE_API_TOKEN works for Zeroscope and Google Veo on Replicate)
REPLICATE_PRIMARY_BASE_URL=https://api.replicate.com/v1
REPLICATE_API_TOKEN=
# Zeroscope (default) or Google Veo — get version from Replicate portal (e.g. google/veo-2, google/veo-3-fast)
TOOLS_VIDEO_MODEL_VERSION=anotherjesse/zeroscope-v2-xl:version_id
# REPLICATE_BASE_URL= (alias for REPLICATE_PRIMARY_BASE_URL)
# TOOLS_VIDEO_MAX_PROMPT_CHARS=500

# Secondary (optional)
# REPLICATE_SECONDARY_BASE_URL=https://api.replicate.com/v1
# REPLICATE_SECONDARY_API_TOKEN=
# TOOLS_VIDEO_SECONDARY_MODEL_VERSION=owner/model:version_id

# ---- Job Applicant workflow (optional) ----
# CEO user id for multi-profile job search (matches dashboard chat user_id)
# AGENT_OS_CEO_USER_ID=default
# Phase 1+: Google Sheets / Drive sync
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# JOB_APPLICANT_SHEET_ID=
# JOB_APPLICANT_GDRIVE_ROOT_FOLDER_ID=
# Setup: node scripts/setup-job-applicant-agents.js
# Pipeline cron — checks each active profile's workflow_schedule (hourly/daily/weekly)
# Use at least hourly for hourly profiles: 0 * * * *
# JOB_PIPELINE_CRON_SCHEDULE=0 * * * *
