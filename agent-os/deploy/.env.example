# Agent OS — production Compose environment
# Copy to .env and fill in secrets before deploy.
# Keys are injected at container runtime — never baked into images or openclaw.json.

# ---- Public URL ----
AGENT_OS_PUBLIC_URL=https://agent-os.example.com
VITE_API_URL=/api

# ---- Gateway auth (written to openclaw.json at init) ----
OPENCLAW_GATEWAY_TOKEN=change-me-generate-a-long-random-token

# ---- Platform admin ----
AGENT_OS_ADMIN_EMAIL=admin@agent-os.local
AGENT_OS_ADMIN_PASSWORD=change-me-admin-password

# ---- OpenClaw gateway + backend: OpenAI (primary) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Aliases (optional — used if OPENAI_API_KEY / OPENAI_BASE_URL not set)
# OPENAI_PRIMARY_API_KEY=
# OPENAI_PRIMARY_BASE_URL=https://api.openai.com/v1
# OPENAI_PRIMARY_MODEL=gpt-4o-mini

# OpenClaw default agent model slug (written to openclaw.json at init)
OPENCLAW_MODEL_PRIMARY=openai/gpt-4o-mini

# ---- Anthropic (OpenClaw gateway — e.g. anthropic/claude-opus-4-6) ----
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=

# ---- Secondary OpenAI-compatible endpoint (optional) ----
# OPENAI_SECONDARY_BASE_URL=https://api.deepseek.com/v1
# OPENAI_SECONDARY_API_KEY=
# OPENAI_SECONDARY_MODEL=deepseek-chat

# ---- Ollama fallback (OpenClaw + optional-ollama profile) ----
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=ollama-local
OPENCLAW_OLLAMA_FALLBACK_MODEL=llama3.2

# ---- OpenRouter (backend dev/scripts; Brain nodes use per-node keys in workflow editor) ----
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_SITE_TITLE=Agent OS

# ---- Backend LLM overrides ----
# OPENAI_COO_MODEL=gpt-4o-mini
# OPENAI_INTENT_MODEL=

# ---- Content tools: Replicate video ----
REPLICATE_API_TOKEN=
# REPLICATE_PRIMARY_BASE_URL=https://api.replicate.com/v1
# TOOLS_VIDEO_MODEL_VERSION=owner/model:version_id
# REPLICATE_SECONDARY_API_TOKEN=

# ---- Job Applicant / browser timeouts (ms) ----
OPENCLAW_DISCOVERY_TIMEOUT_MS=900000
OPENCLAW_FETCH_TIMEOUT_MS=240000
# JOB_PIPELINE_CRON_SCHEDULE=0 * * * *

# ---- Custom workflow scripts (Python/JS sandbox in backend container) ----
# CUSTOM_SCRIPT_MAX_BYTES=131072
# CUSTOM_SCRIPT_TIMEOUT_MS=60000
# CUSTOM_SCRIPT_PYTHON=python3
# CUSTOM_SCRIPT_NODE=node
# LLM security review at registration (uses OPENAI_* / Ollama above — same as backend LLM)
# CUSTOM_SCRIPT_LLM_REVIEW=1
# CUSTOM_SCRIPT_LLM_REVIEW_REQUIRED=1
# CUSTOM_SCRIPT_LLM_REVIEW_MAX_TOKENS=768

# ---- Workflow email (optional) ----
# WORKFLOW_SMTP_HOST=smtp.example.com
# WORKFLOW_SMTP_PORT=587
# WORKFLOW_SMTP_USER=
# WORKFLOW_SMTP_PASS=
# WORKFLOW_SMTP_FROM=agent-os@example.com

# ---- Published ports ----
HTTP_PORT=80
HTTPS_PORT=443
IMAGE_TAG=latest

# ---- Optional profiles ----
MCP_AUTO_EMIT_MS=5000
# WORKFLOW_HOOK_URL=https://agent-os.example.com/api/agent-workflows/hooks/<definitionId>
# WORKFLOW_HOOK_SECRET=
NOVNC_PORT=6080
TZ=Asia/Singapore
ENABLE_VNC=0

# OpenClaw session visibility (init → openclaw.json)
# OPENCLAW_SESSION_VISIBILITY=agent
